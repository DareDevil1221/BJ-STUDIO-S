{
  "entities": {
    "Client": {
      "title": "Client",
      "description": "Represents a studio client with access credentials.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "accessKey": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "accessKey", "createdAt", "updatedAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A photography/editing project for a client.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "name": { "type": "string" },
        "totalImages": { "type": "number" },
        "completedImages": { "type": "number" },
        "pendingImages": { "type": "number" },
        "revisionRoundsMax": { "type": "number" },
        "deliveryDeadline": { "type": "string", "format": "date-time" },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "partial", "paid"] },
        "status": { "type": "string", "enum": ["active", "delivered", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "name", "totalImages", "createdAt", "updatedAt"]
    },
    "Image": {
      "title": "Image",
      "description": "An image within a project.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "clientId": { "type": "string" },
        "url": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "editing", "delivered", "approved"] },
        "revisionCount": { "type": "number" },
        "approved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "clientId", "url", "status", "revisionCount", "approved", "createdAt", "updatedAt"]
    },
    "Revision": {
      "title": "Revision",
      "description": "A revision request for an image.",
      "type": "object",
      "properties": {
        "imageId": { "type": "string" },
        "projectId": { "type": "string" },
        "clientId": { "type": "string" },
        "referenceImageUrl": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["requested", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["imageId", "projectId", "clientId", "description", "status", "createdAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Studio administrator.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["email", "role"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification alert for specific users or admins.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["revision_requested", "project_delivered", "image_approved"] },
        "projectId": { "type": "string" },
        "clientId": { "type": "string" },
        "imageId": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "message", "read", "createdAt"]
    }
  },
  "firestore": {
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Collection of clients."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of projects."
    },
    "/images/{imageId}": {
      "schema": "Image",
      "description": "Collection of images across all projects."
    },
    "/revisions/{revisionId}": {
      "schema": "Revision",
      "description": "Collection of revision requests."
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "Collection of administrators."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Global notification collection."
    }
  }
}
